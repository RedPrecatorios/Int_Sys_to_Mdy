# Copie para .env na VM:  cp .env.example .env  &&  nano .env
#
# Monday.com (obrigatório para inserir itens)
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=7345244366
MONDAY_API_URL=https://api.monday.com/v2

# E-mail de um utilizador Monday (coluna Permissão / people)
PERMISSAO=aline.chaves@redprecatorios.com.br

# Segurança (opcional): allowlist por IP para POST /incluir
# - Vazio = permite qualquer IP
# - Aceita IPs e CIDRs separados por vírgula (ex.: "1.2.3.4, 10.0.0.0/24")
ALLOWED_SOURCE_IPS=
#
# Se você estiver atrás de reverse proxy (Nginx/Traefik/Cloudflare) e quiser usar X-Forwarded-For:
# ATENÇÃO: só ative se você confia no proxy, senão qualquer cliente pode forjar o header.
TRUST_PROXY=false

# Opcional — usados por scripts/run_server.sh
# HOST=0.0.0.0
# PORT=8000

# Auditoria de requisições (POST /incluir)
# - off  : desativa
# - file : grava em JSONL local
# - mysql: grava no MySQL
# - both : grava nos dois
AUDIT_MODE=file
AUDIT_LOG_PATH=logs/requisicoes_incluir.jsonl
#
# Se AUDIT_MODE incluir mysql:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=int_sys_to_mdy
MYSQL_USER=int_sys_to_mdy
MYSQL_PASSWORD=
MYSQL_AUDIT_TABLE=request_audit
